<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Kirish | MILANA PREMIUM</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        body { 
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; 
            background-color: #F2F2F7; /* iOS System Gray 6 */
            -webkit-tap-highlight-color: transparent;
        }

        /* iOS uslubidagi kirish kartasi */
        .login-card {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-radius: 32px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.06);
        }

        /* Inputlar uchun maxsus dizayn */
        .ios-input {
            background-color: #E9E9EB; /* iOS System Gray 5 */
            border: none;
            transition: all 0.2s ease;
        }

        .ios-input:focus {
            background-color: #FFFFFF;
            box-shadow: 0 0 0 4px rgba(0, 122, 255, 0.15);
        }

        /* Tugma bosilish effekti */
        .btn-haptic:active {
            transform: scale(0.97);
            opacity: 0.9;
        }

        @keyframes reveal {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .animate-reveal {
            animation: reveal 0.6s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
        }
    </style>
</head>
<body class="flex items-center justify-center min-h-screen p-6">

    <div class="w-full max-w-[400px] animate-reveal">
        
        <div class="text-center mb-10">
            <h1 class="text-3xl font-bold tracking-tight text-black">MILANA PREMIUM</h1>
            <p class="text-[#8E8E93] font-medium mt-1">Tizimga xush kelibsiz</p>
        </div>

        <div class="login-card p-8 border border-white/20">
            
            {{#if error}}
            <div class="bg-red-50 text-red-600 text-sm font-medium px-4 py-3 rounded-2xl mb-6 text-center border border-red-100">
                ⚠️ {{error}}
            </div>
            {{/if}}

            <form action="/login" method="POST" class="space-y-5">
                <div>
                    <label class="block text-[13px] font-semibold text-gray-500 ml-2 mb-1.5 uppercase tracking-wider">Login</label>
                    <input type="text" 
                           name="username" 
                           required 
                           placeholder="Foydalanuvchi nomi"
                           class="ios-input w-full rounded-2xl px-5 py-4 text-black placeholder-gray-400 outline-none focus:ring-2 focus:ring-blue-500 transition-all font-medium">
                </div>

                <div>
                    <label class="block text-[13px] font-semibold text-gray-500 ml-2 mb-1.5 uppercase tracking-wider">Parol</label>
                    <input type="password" 
                           name="password" 
                           required 
                           placeholder="••••••••"
                           class="ios-input w-full rounded-2xl px-5 py-4 text-black placeholder-gray-400 outline-none focus:ring-2 focus:ring-blue-500 transition-all font-medium">
                </div>

                <div class="pt-2">
                    <button type="submit" 
                            class="btn-haptic w-full bg-[#007AFF] text-white py-4 rounded-2xl font-bold text-lg shadow-lg shadow-blue-500/30 hover:bg-blue-600 transition-all duration-300">
                        Kirish
                    </button>
                </div>
            </form>
        </div>

        <div class="text-center mt-8">
            <a href="/" class="text-blue-600 font-semibold text-sm hover:underline">Asosiy sahifaga qaytish</a>
            <p class="text-[#8E8E93] text-[12px] mt-10">© 2026 MILANA PREMIUM. Barcha huquqlar himoyalangan.</p>
        </div>

    </div>

    <script>
        // iOS-da inputga bosilganda sahifani qimirlatmaslik uchun qo'shimcha
        document.querySelectorAll('input').forEach(input => {
            input.addEventListener('focus', () => {
                window.scrollTo(0, 0);
                document.body.scrollTop = 0;
            });
        });
    </script>
</body>
</html>