<!DOCTYPE html>
<html lang="uz" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title>{{title}}</title>
    <meta name="theme-color" content="#0a0a0c" id="theme-color-meta">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <link rel="manifest" href="/manifest.json">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        ios: {
                            lightBg: '#fbfbfd',
                            darkBg: '#0a0a0c',
                            accent: '#0071e3'
                        }
                    }
                }
            }
        }
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            -webkit-font-smoothing: antialiased;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            letter-spacing: -0.01em;
        }

        .dark body { background-color: #0a0a0c; color: #f5f5f7; }
        body { background-color: #fbfbfd; color: #1d1d1f; }

        @keyframes softEntrance {
            0% { opacity: 0; transform: translateY(30px) scale(0.95); filter: blur(10px); }
            100% { opacity: 1; transform: translateY(0) scale(1); filter: blur(0); }
        }
        .animate-soft {
            animation: softEntrance 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
        }

        .ios-card {
            border-radius: 28px;
            overflow: hidden;
            border: 1px solid rgba(128, 128, 128, 0.1);
            position: relative;
        }
        .dark .ios-card {
            background: linear-gradient(145deg, #161618 0%, #0a0a0c 100%);
            box-shadow: 0 20px 40px rgba(0,0,0,0.4);
        }
        .ios-card {
            background: #ffffff;
            box-shadow: 0 20px 40px rgba(0,0,0,0.03);
        }
        .ios-card:hover {
            transform: scale(1.02);
            border-color: rgba(0, 113, 227, 0.3);
        }

        .ios-glass {
            backdrop-filter: blur(25px) saturate(200%);
            -webkit-backdrop-filter: blur(25px) saturate(200%);
        }
        .dark .ios-glass { background: rgba(10, 10, 12, 0.75); border-bottom: 1px solid rgba(255,255,255,0.05); }
        .ios-glass { background: rgba(255, 255, 255, 0.75); border-bottom: 1px solid rgba(0,0,0,0.05); }

        .ios-button-primary {
            background: #0071e3;
            color: white;
            border-radius: 14px;
            font-weight: 600;
            padding: 12px 24px;
        }

        .ios-button-secondary {
            background: rgba(128, 128, 128, 0.1);
            backdrop-filter: blur(10px);
            border-radius: 14px;
            padding: 10px 20px;
            font-size: 0.9rem;
            font-weight: 500;
        }

        .ios-badge-premium {
            background: linear-gradient(135deg, #ff3b30, #ff7b50);
            color: white;
            padding: 4px 12px;
            border-radius: 10px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
        }
.new-tag {
    background: linear-gradient(135deg, #34c759, #30b0c0);
    box-shadow: 0 4px 12px rgba(52, 199, 89, 0.4);
    animation: pulse-green 2s infinite;
    color: white;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}
        
        .theme-toggle-pill {
            background: rgba(128, 128, 128, 0.1);
            padding: 4px;
            border-radius: 20px;
            display: flex;
            gap: 0;
            position: relative;
            width: 72px;
            height: 36px;
            cursor: pointer;
            border: 1px solid rgba(128, 128, 128, 0.05);
        }

        .theme-toggle-pill::before {
            content: '';
            position: absolute;
            left: 4px;
            top: 4px;
            width: 28px;
            height: 28px;
            background: white;
            border-radius: 50%;
            box-shadow: 0 2px 8px rgba(0,0,0,0.15);
            transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
            z-index: 1;
        }

        .dark .theme-toggle-pill::before {
            transform: translateX(36px);
            background: #1c1c1e;
            box-shadow: 0 2px 8px rgba(0,0,0,0.4);
        }

        .theme-toggle-pill button {
            flex: 1;
            z-index: 2;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            color: #8e8e93;
            transition: color 0.3s;
        }

        .theme-transitioning, .theme-transitioning * {
            transition: background-color 0.5s ease, color 0.5s ease, border-color 0.5s ease !important;
        }

        .dark .theme-toggle-pill .fa-moon { color: #0071e3; }
        html:not(.dark) .theme-toggle-pill .fa-sun { color: #ff9500; }

        @keyframes pulse-green {
            0% { transform: scale(1); }
            50% { transform: scale(1.05); }
            100% { transform: scale(1); }
        }

        @keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
        .animate-spin-fast {
            animation: spin 0.6s linear infinite;
        }
    </style>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body class="antialiased min-h-screen flex flex-col">
    
    <div id="global-loader" class="fixed inset-0 ios-glass flex items-center justify-center z-[100] hidden">
        <div class="animate-pulse flex flex-col items-center">
            <div class="w-16 h-16 border-4 border-blue-500/20 border-t-blue-500 rounded-full animate-spin-fast"></div>
            <p class="mt-4 font-medium opacity-50">Milana Premium</p>
        </div>
    </div>

    <header class="ios-glass sticky top-0 z-40">
        <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
            <a href="/" class="text-xl font-bold tracking-tighter hover:opacity-70">
                MILANA <span class="font-light text-blue-500">PREMIUM</span>
            </a>
            
            <div class="flex items-center gap-6">
                <div class="theme-toggle-pill" id="theme-toggle-wrap">
                    <button type="button" aria-label="Light Mode">
                        <i class="fas fa-sun"></i>
                    </button>
                    <button type="button" aria-label="Dark Mode">
                        <i class="fas fa-moon"></i>
                    </button>
                </div>

                <div class="hidden md:flex items-center gap-4">
                    {{#if user}}
                        <a href="/salesperson" class="text-sm font-medium opacity-70 hover:opacity-100">Savdolarim</a>
                        <a href="/logout" class="ios-button-secondary">Chiqish</a>
                    {{else}}
                        <a href="/login" class="ios-button-secondary">Kirish</a>
                    {{/if}}
                </div>

                <a href="/cart" class="relative p-2 bg-blue-500/10 rounded-full text-blue-500 transition-all active:scale-90">
                    <i class="fas fa-shopping-bag text-lg"></i>
                    <span id="cart-badge-top" class="absolute -top-1 -right-1 bg-red-500 text-white text-[10px] w-5 h-5 flex items-center justify-center rounded-full border-2 border-white dark:border-black font-bold hidden">0</span>
                </a>
            </div>
        </div>
    </header>

    <section class="max-w-4xl mx-auto px-6 py-20 text-center">
        <span class="ios-badge-premium mb-4 inline-block animate-soft">Yangi Fasl 2026</span>
        <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-6 animate-soft">
            Mukammallik <br> <span class="text-blue-500">tafsilotlarda.</span>
        </h1>
        <div class="flex flex-wrap justify-center gap-4 animate-soft">
            <button class="ios-button-primary">Kolleksiyani ko'rish</button>
            <button id="about-us-btn" class="ios-button-secondary flex items-center gap-2 py-[12px] px-6 active:scale-95">
                <i class="fas fa-play-circle text-blue-500 text-lg"></i> Biz haqimizda
            </button>
        </div>
    </section>

    

    <section class="max-w-7xl mx-auto px-4 md:px-6 pb-32 flex-grow">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
            {{#each products}}
            <div class="ios-card opacity-0 animate-soft group" style="animation-delay: 0.2s">
    <div class="relative aspect-[4/5] bg-[#f2f2f7] dark:bg-[#1c1c1e] overflow-hidden cursor-pointer image-trigger" data-image="{{this.image}}">
        {{#if this.isNewProduct}} 
            <div class="absolute top-4 right-4 z-20 new-tag text-white px-3 py-1 rounded-lg text-[10px] font-bold uppercase tracking-wider">
                Yangi
            </div>
        {{/if}}
        {{#if this.promotion}}
            <div class="absolute top-4 left-4 z-10 ios-badge-premium">Aksiya</div>
        {{/if}}
        <img src="{{this.image}}" alt="{{this.name}}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
        <div class="absolute inset-0 bg-black/0 group-hover:bg-black/5 transition-all"></div>
    </div>
    
    <div class="p-6">
        <h3 class="text-lg font-semibold mb-1 truncate">{{this.name}}</h3>
        <p class="text-sm opacity-50 mb-4 font-light">Eksklyuziv mahsulot</p>
        <div class="flex items-center justify-between">
            <span class="text-xl font-bold text-blue-500">${{this.price}}</span>
            <button class="w-10 h-10 rounded-xl bg-blue-500 text-white flex items-center justify-center hover:bg-blue-600 active:scale-90 add-to-cart-btn" data-product-id="{{this._id}}">
                <i class="fas fa-plus"></i>
            </button>
        </div>
    </div>
</div>
            {{/each}}
        </div>
    </section>

    {{#if (gt totalPages 1)}}
<div class="flex justify-center items-center gap-2 mt-16 pb-8">
  {{#if hasPrev}}
    <a href="?page={{subtract currentPage 1}}" class="w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center transition">
      <i class="fas fa-chevron-left text-sm"></i>
    </a>
  {{else}}
    <span class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center opacity-30 cursor-not-allowed">
      <i class="fas fa-chevron-left text-sm"></i>
    </span>
  {{/if}}

  {{#each (range 1 totalPages)}}
    {{#if (eq this ../currentPage)}}
      <span class="w-10 h-10 rounded-full bg-blue-500 text-white flex items-center justify-center font-medium shadow-lg shadow-blue-500/30">{{this}}</span>
    {{else}}
      <a href="?page={{this}}" class="w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center transition">{{this}}</a>
    {{/if}}
  {{/each}}

  {{#if hasNext}}
    <a href="?page={{add currentPage 1}}" class="w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center transition">
      <i class="fas fa-chevron-right text-sm"></i>
    </a>
  {{else}}
    <span class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center opacity-30 cursor-not-allowed">
      <i class="fas fa-chevron-right text-sm"></i>
    </span>
  {{/if}}
</div>
{{/if}}

    <div id="videoModal" class="fixed inset-0 bg-black/60 backdrop-blur-xl z-[100] hidden items-center justify-center p-4 md:p-10">
        <div class="relative w-full max-w-5xl aspect-video bg-black rounded-3xl overflow-hidden shadow-2xl border border-white/10">
            <button id="closeVideoModal" class="absolute top-4 right-4 z-[110] w-10 h-10 bg-black/20 hover:bg-black/40 text-white rounded-full flex items-center justify-center transition-all backdrop-blur-md">
                <i class="fas fa-times"></i>
            </button>
            <div id="player-container" class="w-full h-full"></div>
        </div>
    </div>

    <div id="imageModal" class="fixed inset-0 bg-white/80 dark:bg-black/90 backdrop-blur-xl z-[100] hidden items-center justify-center p-6">
        <button id="closeImageModal" class="absolute top-10 right-10 text-3xl opacity-50 hover:opacity-100"><i class="fas fa-times"></i></button>
        <img id="modalImage" src="" class="max-w-full max-h-[80vh] rounded-3xl shadow-2xl">
    </div>

    <!-- ========== MOBILE NAV (O'ZGARTIRILGAN QISM) ========== -->
    <nav class="fixed bottom-6 left-1/2 -translate-x-1/2 w-[90%] md:hidden ios-glass border rounded-3xl z-50 py-3 px-2 shadow-2xl">
        <div class="flex justify-around items-center">
            <a href="/" class="p-3 text-blue-500"><i class="fas fa-house text-xl"></i></a>
            <a href="/cart" class="p-3 opacity-40 relative">
                <i class="fas fa-bag-shopping text-xl"></i>
                <span id="cart-badge-bottom" class="absolute top-2 right-2 bg-red-500 text-white text-[8px] w-4 h-4 flex items-center justify-center rounded-full font-bold hidden">0</span>
            </a>

            <!-- Mobil uchun login / chiqish tugmalari -->
            {{#if user}}
                <!-- Agar foydalanuvchi kirgan bo'lsa: Savdolarim va Chiqish -->
                <a href="/salesperson" class="p-3 opacity-40" title="Savdolarim">
                    <i class="fas fa-chart-line text-xl"></i>
                </a>
                <a href="/logout" class="p-3 opacity-40" title="Chiqish">
                    <i class="fas fa-sign-out-alt text-xl"></i>
                </a>
            {{else}}
                <!-- Aks holda: Kirish (user icon) -->
                <a href="/login" class="p-3 opacity-40" title="Kirish">
                    <i class="fas fa-user text-xl"></i>
                </a>
            {{/if}}

            <button id="theme-toggle-mobile" class="p-3 opacity-40"><i class="fas fa-circle-half-stroke text-xl"></i></button>
        </div>
    </nav>

    <script>
        const html = document.documentElement;
        const themeToggleWrap = document.getElementById('theme-toggle-wrap');
        const themeToggleMobile = document.getElementById('theme-toggle-mobile');
        const badgeTop = document.getElementById('cart-badge-top');
        const badgeBottom = document.getElementById('cart-badge-bottom');

        // Savat sonini yangilash
        function updateCartCount() {
            fetch('/cart-data')
                .then(res => res.json())
                .then(data => {
                    const total = data.totalItems || 0;
                    [badgeTop, badgeBottom].forEach(badge => {
                        if (badge) {
                            if (total > 0) {
                                badge.textContent = total > 9 ? '9+' : total;
                                badge.classList.remove('hidden');
                                badge.animate([{transform: 'scale(1)'}, {transform: 'scale(1.3)'}, {transform: 'scale(1)'}], {duration: 300});
                            } else {
                                badge.classList.add('hidden');
                            }
                        }
                    });
                });
        }

        function toggleTheme() {
            document.documentElement.classList.add('theme-transitioning');
            html.classList.toggle('dark');
            const isDark = html.classList.contains('dark');
            localStorage.theme = isDark ? 'dark' : 'light';
            document.getElementById('theme-color-meta').content = isDark ? '#0a0a0c' : '#fbfbfd';
            setTimeout(() => {
                document.documentElement.classList.remove('theme-transitioning');
            }, 400);
        }

        themeToggleWrap.onclick = toggleTheme;
        if(themeToggleMobile) themeToggleMobile.onclick = toggleTheme;

        document.addEventListener('DOMContentLoaded', function() {
            updateCartCount();

            // Image Modal
            document.querySelectorAll('.image-trigger').forEach(img => {
                img.onclick = function() {
                    document.getElementById('modalImage').src = this.dataset.image;
                    document.getElementById('imageModal').classList.remove('hidden');
                    document.getElementById('imageModal').style.display = 'flex';
                }
            });

            document.getElementById('closeImageModal').onclick = () => {
                document.getElementById('imageModal').classList.add('hidden');
                document.getElementById('imageModal').style.display = 'none';
            }

            // Video Modal
            const videoModal = document.getElementById('videoModal');
            const aboutBtn = document.getElementById('about-us-btn');
            const closeVideo = document.getElementById('closeVideoModal');
            const playerContainer = document.getElementById('player-container');

            aboutBtn.onclick = function() {
                playerContainer.innerHTML = `
                    <iframe 
                        src="https://www.youtube.com/embed/jwbUzhjyrdA?autoplay=1&start=83" 
                        class="w-full h-full" 
                        frameborder="0" 
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                        allowfullscreen>
                    </iframe>`;
                videoModal.classList.remove('hidden');
                videoModal.style.display = 'flex';
            };

            closeVideo.onclick = function() {
                videoModal.classList.add('hidden');
                videoModal.style.display = 'none';
                playerContainer.innerHTML = '';
            };

            videoModal.onclick = function(e) {
                if (e.target === videoModal) closeVideo.onclick();
            };

            // Add to Cart
            document.querySelectorAll('.add-to-cart-btn').forEach(btn => {
                btn.onclick = function() {
                    const id = this.dataset.productId;
                    const originalContent = this.innerHTML;
                    this.disabled = true;
                    this.innerHTML = '<i class="fas fa-circle-notch animate-spin-fast"></i>';
                    
                    fetch(`/add-to-cart/${id}`, { method: 'POST' })
                        .then(res => res.json())
                        .then(data => {
                            if(data.success) {
                                updateCartCount();
                                this.innerHTML = '<i class="fas fa-check"></i>';
                                this.style.backgroundColor = '#34c759';
                                setTimeout(() => {
                                    this.innerHTML = originalContent;
                                    this.style.backgroundColor = '';
                                    this.disabled = false;
                                }, 1500);
                            }
                        }).catch(() => {
                            this.innerHTML = originalContent;
                            this.disabled = false;
                        });
                }
            });
        });
    </script>
</body>
</html>