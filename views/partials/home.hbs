</div>





        </div>
    </section>

    <!-- Footer -->
    <footer class="border-t border-gray-200 py-8 text-center text-gray-400 text-sm">
        <div class="max-w-7xl mx-auto px-5">
            © 2025 minimal. Barcha huquqlar himoyalangan.
        </div>
    </footer>

    <!-- Tugmalar interaktivligi (ixtiyoriy) -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const buyButtons = document.querySelectorAll('.product-card button');
            buyButtons.forEach(button => {
                button.addEventListener('click', function(e) {
                    e.preventDefault();
                    const productName = this.closest('.product-card').querySelector('h3').innerText;
                    alert(`"${productName}" savatga qo'shildi!`);
                });
            });
            const allProductsBtn = document.querySelector('section.text-center button');
            if (allProductsBtn) {
                allProductsBtn.addEventListener('click', function() {
                    alert('Barcha mahsulotlar sahifasiga o\'tilmoqda...');
                });
            }
            const cartIcon = document.querySelector('header .flex .text-xl');
            if (cartIcon) {
                cartIcon.addEventListener('click', function() {
                    alert('Savatcha hozircha bo‘sh. Mahsulot qo‘shing!');
                });
            }
        });
    </script>
</body>
</html>