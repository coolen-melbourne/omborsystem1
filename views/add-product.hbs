<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50">
    <div class="max-w-2xl mx-auto px-5 py-10">
        <h1 class="text-3xl font-light mb-5">Yangi mahsulot qo'shish</h1>
        <form action="/add-product" method="POST" class="space-y-4">
            <div>
                <label class="block text-sm font-medium mb-1">Mahsulot nomi</label>
                <input type="text" name="name" required class="w-full border border-gray-300 rounded-lg px-4 py-2">
            </div>
            <div>
                <label class="block text-sm font-medium mb-1">Narxi</label>
                <input type="number" name="price" required class="w-full border border-gray-300 rounded-lg px-4 py-2">
            </div>
            <button type="submit" class="bg-gray-900 text-white px-6 py-2 rounded-lg hover:bg-gray-700">Qo'shish</button>
        </form>
    </div>
</body>
</html>